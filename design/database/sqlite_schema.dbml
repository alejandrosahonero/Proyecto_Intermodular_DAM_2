// Use dbdiagram.io to visualize this schema

Table users {
  id integer [primary key]
  uid_firebase varchar [note: 'UID de Firebase Auth para sincronización']
  name varchar
  email varchar
  role varchar [note: 'admin | client']
  fcm_token varchar
  created_at timestamp
}

Table courts {
  id integer [primary key]
  name varchar
  type varchar
  price_per_hour float
  is_enabled boolean
  description text
  image_url varchar
  disabled_reason text
}

Table reservations {
  id integer [primary key]
  user_id integer [not null]
  court_id integer [not null]
  date date [note: 'Formato YYYY-MM-DD']
  start_time time [note: 'HH:mm']
  end_time time
  status varchar [note: 'confirmed | cancelled | expired']
  total_price float
  payment_id varchar
  access_code varchar
  access_code_status varchar [note: 'pending | used | expired']
  qr_data text
  created_at timestamp
  scanned_at timestamp
}

Table notifications {
  id integer [primary key]
  user_id integer [not null]
  title varchar
  body text
  type varchar
  is_read boolean
  created_at timestamp
}

// Relaciones
Ref: reservations.user_id > users.id // Many-to-one
Ref: reservations.court_id > courts.id // Many-to-one
Ref: notifications.user_id > users.id // Many-to-one